# API Configuration
# Backend API base URL (without trailing slash)
# For local development: http://127.0.0.1:8000/api
# For production: https://your-backend-domain.com/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Optional: Environment identifier
# Values: development, staging, production
VITE_ENV=development

# Optional: Application name
VITE_APP_NAME=Clink Psychology Clinic

# Optional: Enable/disable debug mode
VITE_DEBUG=false

# Stripe (publishable key only — never commit secret keys). Required for card checkout.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: Plausible Analytics (https://plausible.io) — domain as configured in Plausible, e.g. yourdomain.com
# VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# Optional: Hotjar site ID (numeric). Injected after first paint via App bootstrap.
# VITE_HOTJAR_ID=1234567
